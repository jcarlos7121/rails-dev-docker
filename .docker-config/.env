RAILS_ENV=development
GIT_EDITOR=/usr/local/bin/nvim

# Prevent Letter Opener from trying to open the browser to view emails
LAUNCHY_DRY_RUN=true
BROWSER=/dev/null

# Database configuration for development environment
PGUSER=postgres
PGPASSWORD=password

# Using a custom timezone to ensure that all timestamps are consistent across development environments
TZ=Asia/Bangkok
PGTZ=Asia/Bangkok

# Use sockets instead of TCP for local connections to Postgres and Redis
PGHOST=/var/run/postgresql
REDIS_URL=/data/socket/redis.sock

# Enable Ruby's debug gem to allow remote debugging sessions
RUBY_DEBUG_PORT=38698
RUBY_DEBUG_HOST=0.0.0.0
RUBY_DEBUG_IRB_CONSOLE=1

# Use Playwright for system tests, connecting to the browser server in the playwright
# container (BrowserType.connect). The /connect path matches the launchServer wsPath in
# entrypoint-playwright.sh. Set HEADLESS_SYSTEM_TESTS=1 to launch the browser headless (default headed for VNC).
PLAYWRIGHT_HOST=ws://playwright:8888/connect
HEADLESS_SYSTEM_TESTS=0

# Use a shared volume for gems to speed up bundle install and reduce disk usage across multiple containers
NODE_MODULES_VOLUME=${PROJECT_PREFIX}_shared_node_modules
NPM_GLOBAL_VOLUME=${PROJECT_PREFIX}_shared_npm_global

# Custom terminal settings for development environment in containers
# (SSH_PATH is derived from $HOME in .mise/config.toml, not hardcoded here)
TERM=xterm-kitty
SHELL=/bin/zsh

SKIP_TEST_DATABASE_TRUNCATE=1

GH_TOKEN=${GH_TOKEN}

# Set the default editor for Git to Neovim, which is installed in the container
EDITOR=nvim

# Set a flag to indicate that the application is running in a Docker container, which can be used in the codebase to conditionally adjust behavior for development vs production environments
# Currently used to set OSC52 clipboard support for Neovim
DOCKER=1

# Claude Code in the `claude` container authenticates via OAuth login (your
# Claude subscription) by default. Do NOT set ANTHROPIC_API_KEY here unless you
# explicitly want metered API billing instead.
